#include <stdio.h>
#include <math.h>

int main() {
    float r, result;

    printf("Enter radius value: ");
    scanf("%f", &r);

    result = sqrt(r * r);

    printf("Verified radius (sqrt(r^2)) = %.2f\n", result);

    return 0;
}

