#include <stdio.h>

int main() {
    int a[5], i, j, temp;

    printf("Enter 5 elements:\n");
    for(i = 0; i < 5; i++)
        scanf("%d", &a[i]);

    for(i = 0; i < 5 - 1; i++) {
        for(j = 0; j < 5 - i - 1; j++) {
            if(a[j] > a[j + 1]) {
                temp = a[j];
                a[j] = a[j + 1];
                a[j + 1] = temp;
            }
        }
    }

    printf("Sorted array (Bubble Sort): ");
    for(i = 0; i < 5; i++)
        printf("%d ", a[i]);

    return 0;
}

OUTPUT:Enter 5 elements:
5 4 3 2 1
Sorted array (Bubble Sort): 1 2 3 4 5
