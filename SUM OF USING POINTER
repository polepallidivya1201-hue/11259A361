#include <stdio.h>

int main() {
    int a[5], i, sum = 0;
    int *p;

    printf("Enter 5 elements:\n");
    for(i = 0; i < 5; i++)
        scanf("%d", &a[i]);

    p = a;

    for(i = 0; i < 5; i++) {
        sum = sum + *(p + i);
    }

    printf("Sum = %d", sum);

    return 0;
}

