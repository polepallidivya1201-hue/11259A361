#include <stdio.h>

int main() {
    float A, B, C, score;

    printf("Enter values of A, B, C: ");
    scanf("%f %f %f", &A, &B, &C);

    // Check to avoid division by zero
    if (A == 0) {
        printf("Error: Division by zero (A should not be 0)\n");
        return 0;
    }

    score = A + B + (2 * C) / (3 * A) + (A * A) + 2 * B;

    printf("Student Score = %.2f\n", score);

    return 0;
}

